[sub_resource type="GDScript" id="GDScript_ground_visual"]
script/source = "extends Node2D
# Draws a simple colour-blocked street floor so the scene is immediately
# playable without any external art assets.

const STAGE_WIDTH  : int = 2000
const LANE_TOP     : int = 280
const LANE_BOTTOM  : int = 480
const SKY_BOTTOM   : int = 280

func _draw() -> void:
	# Sky gradient (two-tone)
	draw_rect(Rect2(0, 0, STAGE_WIDTH, SKY_BOTTOM),          Color(\"#1a1a2e\"))
	draw_rect(Rect2(0, SKY_BOTTOM - 80, STAGE_WIDTH, 80),    Color(\"#16213e\"))

	# Background buildings (silhouettes)
	_draw_buildings()

	# Street lane
	draw_rect(Rect2(0, LANE_TOP, STAGE_WIDTH, LANE_BOTTOM - LANE_TOP), Color(\"#2b2b2b\"))

	# Lane stripe
	for i in range(0, STAGE_WIDTH, 80):
		draw_rect(Rect2(i, LANE_TOP + (LANE_BOTTOM - LANE_TOP) / 2 - 2, 40, 4), Color(\"#555555\"))

	# Foreground kerb
	draw_rect(Rect2(0, LANE_BOTTOM, STAGE_WIDTH, 20), Color(\"#444444\"))
	draw_rect(Rect2(0, LANE_BOTTOM + 20, STAGE_WIDTH, 200), Color(\"#1a1a1a\"))

func _draw_buildings() -> void:
	var buildings := [
		{\"x\": 0,    \"w\": 160, \"h\": 200, \"color\": Color(\"#0f3460\")},
		{\"x\": 170,  \"w\": 120, \"h\": 150, \"color\": Color(\"#162447\")},
		{\"x\": 300,  \"w\": 200, \"h\": 240, \"color\": Color(\"#0f3460\")},
		{\"x\": 510,  \"w\": 140, \"h\": 180, \"color\": Color(\"#1a1a4e\")},
		{\"x\": 660,  \"w\": 180, \"h\": 220, \"color\": Color(\"#0f3460\")},
		{\"x\": 850,  \"w\": 130, \"h\": 160, \"color\": Color(\"#162447\")},
		{\"x\": 990,  \"w\": 210, \"h\": 250, \"color\": Color(\"#0f3460\")},
		{\"x\": 1210, \"w\": 150, \"h\": 190, \"color\": Color(\"#1a1a4e\")},
		{\"x\": 1370, \"w\": 170, \"h\": 210, \"color\": Color(\"#0f3460\")},
		{\"x\": 1550, \"w\": 200, \"h\": 170, \"color\": Color(\"#162447\")},
		{\"x\": 1760, \"w\": 240, \"h\": 230, \"color\": Color(\"#0f3460\")},
	]
	for b in buildings:
		var top : int = SKY_BOTTOM - b[\"h\"]
		draw_rect(Rect2(b[\"x\"], top, b[\"w\"], b[\"h\"]), b[\"color\"])
		# Window rows
		var win_color := Color(\"#f5a623\", 0.6)
		var win_off_color := Color(\"#333333\", 0.8)
		for row in range(2, b[\"h\"] / 20):
			for col in range(1, b[\"w\"] / 18):
				var lit := (row + col) % 3 != 0
				draw_rect(
					Rect2(b[\"x\"] + col * 18 - 10, top + row * 20, 8, 10),
					win_color if lit else win_off_color
				)
"

